  "components": {
    "schemas": {
      "CreateAppointmentDto": {
        "required": [
          "appointmentDate",
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "type": "string"
          },
          "notes": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "appointmentDate": {
            "type": "string",
            "format": "date-time"
          },
          "patientId": {
            "type": "integer",
            "format": "int32"
          },
          "doctorId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateMedicalRecordDto": {
        "required": [
          "diagnosis"
        ],
        "type": "object",
        "properties": {
          "diagnosis": {
            "minLength": 1,
            "type": "string"
          },
          "treatment": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
